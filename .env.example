# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# LINE
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_BOT_USER_ID=your_line_bot_user_id

# Notion
NOTION_API_KEY=your_notion_api_key
NOTION_DATABASE_ID=your_notion_database_id

# Google Calendar
GOOGLE_CALENDAR_ID=your_calendar_id@gmail.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# ===== メール送信機能（LINE→メール） =====
# 送信元Gmailアドレス（既定: mdnext.proposer@gmail.com）
GMAIL_SENDER=mdnext.proposer@gmail.com
# 署名に使う名前/会社名
GMAIL_SENDER_NAME=MDNEXT
# 送信元Gmailの「アプリパスワード」（2段階認証をONにして発行した16文字。空白は自動除去）。
GMAIL_APP_PASSWORD=your_gmail_app_password
# 既定の差出人ラベル（指定なし時の送信元。省略時は「会社」）
GMAIL_DEFAULT_LABEL=会社
# 既定（会社）アカウントの署名ブロック。改行は \n。メール末尾に自動付与。
# 例: GMAIL_DEFAULT_SIGNATURE=MD NEXT株式会社\n代表取締役 前田誠司\n〒000-0000 東京都...\nTEL: 03-0000-0000
GMAIL_DEFAULT_SIGNATURE=

# 追加の差出人（複数登録・LINEで「自分から」「社長名義で」等と指定して切替）。
# 各人のGmailで発行したアプリパスワードが必要。JSONで登録:
# GMAIL_ACCOUNTS={"下村":{"email":"mdnext.shimomura@gmail.com","password":"xxxxxxxxxxxxxxxx","name":"MDNEXT 下村"}}
GMAIL_ACCOUNTS={}

# 名前→メールアドレスの社内台帳（JSON）
# 例: {"田中":"tanaka@example.com","山田不動産 佐藤":"sato@yamada.co.jp"}
EMAIL_CONTACTS={}

# メール意図と判定する最低確信度（既定0.7）。未満は既存のタスク処理へ流す。
EMAIL_INTENT_THRESHOLD=0.7

# 確認セッション保存用 Vercel KV（Vercelダッシュボードで KV を作成すると自動注入される）。
# 未設定でもビルド・起動は可能だが、下書きの確認→送信は同一インスタンス内でのみ動作する。
KV_REST_API_URL=your_vercel_kv_rest_api_url
KV_REST_API_TOKEN=your_vercel_kv_rest_api_token
